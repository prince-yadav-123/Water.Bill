@{
    ViewBag.Title = "Notifications";
    ViewBag.Route = "notifications";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-head">
    <div><h1 class="page-title">Notifications</h1><div class="page-sub">Alerts about your bills, payments and services.</div></div>
    <button class="btn"><i class="fa fa-check-double"></i> Mark all read</button>
</div>

<div class="seg">
    <button class="seg-btn active" data-tabgroup="notif" data-tabkey="all" onclick="njSwitchTab('notif','all')">All <span class="chip">12</span></button>
    <button class="seg-btn" data-tabgroup="notif" data-tabkey="bills" onclick="njSwitchTab('notif','bills')">Bills</button>
    <button class="seg-btn" data-tabgroup="notif" data-tabkey="alerts" onclick="njSwitchTab('notif','alerts')">Alerts</button>
    <button class="seg-btn" data-tabgroup="notif" data-tabkey="updates" onclick="njSwitchTab('notif','updates')">Updates</button>
</div>

<div class="panel">
    @{
        var notifs = new[] {
            new { K="bills",   I="receipt", IT="brand", T="March bill is ready &middot; &#8377; 1,847", S="Due 15 May. Pay before due date to avoid late fee.", Time="2h ago", New=true },
            new { K="alerts",  I="triangle-exclamation", IT="warn", T="Unusual consumption detected", S="Daily flow on 12-14 Mar averaged 1.8&times; — inspect for leaks.", Time="Yesterday", New=true },
            new { K="updates", I="wrench", IT="info",  T="Scheduled maintenance &middot; Sector 50", S="Water supply will be interrupted on 18 Apr, 11 AM-1 PM.", Time="2 days ago", New=true },
            new { K="bills",   I="check",  IT="ok",    T="Payment received &middot; &#8377; 1,654", S="UPI &middot; HDFC &middot; for NJB-202602-71204.", Time="12 Mar", New=false },
            new { K="alerts",  I="bell",   IT="brand", T="Complaint NJC-78421 resolved", S="Inlet leak fixed. Please rate your experience.", Time="14 Mar", New=false },
            new { K="updates", I="megaphone", IT="info", T="New tariff slabs effective 01 Apr", S="Domestic-II base slab raised to 25 kL. Read details.", Time="28 Feb", New=false }
        };
    }
    @foreach (var n in notifs)
    {
        <div class="notif-row @(n.New ? "new" : "") " data-tabpanel="notif" data-tabkey="all">
            <div class="notif-ic @n.IT"><i class="fa fa-@n.I"></i></div>
            <div class="notif-body">
                <div class="notif-t">@Html.Raw(n.T) @if (n.New) { <span class="dot-new"></span> }</div>
                <div class="notif-s">@Html.Raw(n.S)</div>
            </div>
            <div class="notif-time">@n.Time</div>
        </div>
    }
</div>
