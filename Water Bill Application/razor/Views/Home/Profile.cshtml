@{
    ViewBag.Title = "Profile";
    ViewBag.Route = "profile";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-head"><div><h1 class="page-title">Profile &amp; connections</h1><div class="page-sub">Manage your account, properties and preferences.</div></div></div>

<div class="profile-head">
    <div class="profile-av">AS</div>
    <div>
        <div class="profile-name">Aarav Sharma</div>
        <div class="profile-sub">aarav.sharma@@gmail.com &middot; +91 98XXX XXXXX</div>
        <div class="profile-chips">
            <span class="chip ok">KYC verified</span>
            <span class="chip">Customer since Jun 2019</span>
            <span class="chip">2 connections</span>
        </div>
    </div>
    <button class="btn"><i class="fa fa-pen"></i> Edit profile</button>
</div>

<div class="seg" style="margin-top:24px">
    <button class="seg-btn active" data-tabgroup="prof" data-tabkey="conn" onclick="njSwitchTab('prof','conn')">Connections</button>
    <button class="seg-btn" data-tabgroup="prof" data-tabkey="pay" onclick="njSwitchTab('prof','pay')">Payment methods</button>
    <button class="seg-btn" data-tabgroup="prof" data-tabkey="pref" onclick="njSwitchTab('prof','pref')">Preferences</button>
    <button class="seg-btn" data-tabgroup="prof" data-tabkey="sec" onclick="njSwitchTab('prof','sec')">Security</button>
</div>

<div data-tabpanel="prof" data-tabkey="conn">
    <div class="conn-grid">
        <div class="conn-card primary">
            <div class="conn-card-head"><i class="fa fa-home"></i><span class="chip ok">Primary</span></div>
            <div class="conn-card-t">Sector 50 &middot; A-123</div>
            <div class="conn-card-s mono">NJL-20A-184721</div>
            <div class="conn-card-meta">Domestic-II &middot; Active &middot; Since 2019</div>
            <div class="conn-card-foot"><a href="#">View bills</a><a href="#">Settings</a></div>
        </div>
        <div class="conn-card">
            <div class="conn-card-head"><i class="fa fa-building"></i></div>
            <div class="conn-card-t">Sector 18 &middot; Shop 14</div>
            <div class="conn-card-s mono">NJL-18C-209174</div>
            <div class="conn-card-meta">Commercial-I &middot; Active &middot; Since 2022</div>
            <div class="conn-card-foot"><a href="#">View bills</a><a href="#">Settings</a></div>
        </div>
        <a class="conn-card add" href="@Url.Action("NewConnection","Home")">
            <i class="fa fa-plus-circle"></i>
            <div>Add a connection</div>
            <div class="conn-card-meta">Existing or new application</div>
        </a>
    </div>
</div>

<div data-tabpanel="prof" data-tabkey="pay" style="display:none">
    <div class="panel">
        <div class="panel-head"><div class="panel-title">Saved payment methods</div><button class="btn btn-sm">+ Add method</button></div>
        <div class="pm-row"><i class="fa fa-mobile-screen"></i><div><strong>aarav@@oksbi</strong><span>UPI &middot; SBI</span></div><span class="chip ok">Default</span></div>
        <div class="pm-row"><i class="fa fa-credit-card"></i><div><strong>HDFC •••• 4218</strong><span>Visa Credit &middot; exp 09/28</span></div><a href="#">Remove</a></div>
        <div class="pm-row"><i class="fa fa-building-columns"></i><div><strong>ICICI Net Banking</strong><span>Auto-fill enabled</span></div><a href="#">Remove</a></div>
    </div>
</div>

<div data-tabpanel="prof" data-tabkey="pref" style="display:none">
    <div class="panel">
        <div class="pref-row"><div><strong>Language</strong><span>Interface and notifications</span></div>
            <div class="seg sm"><button class="seg-btn active">English</button><button class="seg-btn">हिन्दी</button></div>
        </div>
        <div class="pref-row"><div><strong>Bill alerts</strong><span>SMS, Email, WhatsApp</span></div>
            <label class="switch"><input type="checkbox" checked /><span></span></label>
        </div>
        <div class="pref-row"><div><strong>Autopay</strong><span>Auto-pay 1 day before due date</span></div>
            <label class="switch"><input type="checkbox" /><span></span></label>
        </div>
        <div class="pref-row"><div><strong>Paperless billing</strong><span>Don't send a paper bill</span></div>
            <label class="switch"><input type="checkbox" checked /><span></span></label>
        </div>
    </div>
</div>

<div data-tabpanel="prof" data-tabkey="sec" style="display:none">
    <div class="panel">
        <div class="pref-row"><div><strong>Password</strong><span>Last changed 4 months ago</span></div><a class="btn btn-sm" href="#">Change</a></div>
        <div class="pref-row"><div><strong>Two-factor auth</strong><span>SMS OTP on new device</span></div><label class="switch"><input type="checkbox" checked /><span></span></label></div>
        <div class="pref-row"><div><strong>Biometric login</strong><span>Face / fingerprint on mobile</span></div><label class="switch"><input type="checkbox" checked /><span></span></label></div>
        <div class="pref-row danger"><div><strong>Sign out everywhere</strong><span>Removes all active sessions</span></div><button class="btn btn-sm danger">Sign out</button></div>
    </div>
</div>
