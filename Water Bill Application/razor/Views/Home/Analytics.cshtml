@{
    ViewBag.Title = "Usage Analytics";
    ViewBag.Route = "analytics";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-head">
    <div><h1 class="page-title">Usage analytics</h1><div class="page-sub">Daily consumption, breakdown and ward comparison.</div></div>
    <select class="select"><option>Last 30 days</option><option>This billing cycle</option><option>Last 12 months</option></select>
</div>

<div class="kpi-row">
    <div class="stat-card"><div class="stat-label"><i class="fa fa-droplet"></i> Total this cycle</div><div class="stat-value">24.5 <span>kL</span></div><div class="stat-foot trend-up">+11.4%</div></div>
    <div class="stat-card"><div class="stat-label"><i class="fa fa-calendar-day"></i> Daily avg</div><div class="stat-value">820 <span>L</span></div><div class="stat-foot">Target 750 L</div></div>
    <div class="stat-card"><div class="stat-label"><i class="fa fa-arrow-up"></i> Peak day</div><div class="stat-value">1.84 <span>kL</span></div><div class="stat-foot">14 Mar (leak?)</div></div>
    <div class="stat-card"><div class="stat-label"><i class="fa fa-users"></i> Ward avg</div><div class="stat-value">27.8 <span>kL</span></div><div class="stat-foot trend-up">12% below</div></div>
</div>

<div class="panel" style="margin-top:24px">
    <div class="panel-head">
        <div><div class="panel-title">Daily consumption</div><div class="panel-sub">litres per day &middot; 01-31 Mar 2026</div></div>
        <div class="legend"><span class="lg-dot a"></span> Daily use <span class="lg-dot b"></span> Target</div>
    </div>
    <div class="chart-area tall">
        <div class="bars dense">
            @{
                var dailyData = new[] { 720,680,910,820,640,790,1100,830,760,920,810,1400,1820,1840,1100,790,820,860,720,810,930,990,810,720,860,890,910,820,830,790,720 };
                int dmax = 2000;
            }
            @for (int d = 0; d < dailyData.Length; d++)
            {
                var h = (int)Math.Round(dailyData[d] / (double)dmax * 100);
                var spike = dailyData[d] > 1300 ? " spike" : "";
                <div class="bar-wrap" title="Day @(d+1): @dailyData[d] L">
                    <div class="bar@spike" style="height:@(h)%"></div>
                    @if ((d+1) % 5 == 0 || d == 0) { <div class="bar-label">@(d+1)</div> } else { <div class="bar-label">&nbsp;</div> }
                </div>
            }
        </div>
    </div>
</div>

<div class="two-col" style="margin-top:24px">
    <div class="panel">
        <div class="panel-title">Where it goes</div>
        <div class="panel-sub" style="margin-bottom:18px">Estimated breakdown for an average 4-person household</div>
        <div class="bar-h"><div class="bar-h-l">Bath &amp; shower</div><div class="bar-h-track"><div style="width:34%;background:var(--brand)"></div></div><div class="bar-h-v">34%</div></div>
        <div class="bar-h"><div class="bar-h-l">Toilet flush</div><div class="bar-h-track"><div style="width:24%;background:var(--brand-700)"></div></div><div class="bar-h-v">24%</div></div>
        <div class="bar-h"><div class="bar-h-l">Kitchen</div><div class="bar-h-track"><div style="width:18%;background:var(--brand-500)"></div></div><div class="bar-h-v">18%</div></div>
        <div class="bar-h"><div class="bar-h-l">Laundry</div><div class="bar-h-track"><div style="width:14%;background:var(--brand-400)"></div></div><div class="bar-h-v">14%</div></div>
        <div class="bar-h"><div class="bar-h-l">Cleaning &amp; other</div><div class="bar-h-track"><div style="width:10%;background:var(--brand-300)"></div></div><div class="bar-h-v">10%</div></div>
    </div>

    <div class="panel">
        <div class="panel-title">Smart tips</div>
        <ul class="tip-list big">
            <li><i class="fa fa-shower"></i><div><strong>Cut shower by 2 min.</strong> Saves ~3.2 kL/month &middot; &#8377; 240</div></li>
            <li><i class="fa fa-toilet"></i><div><strong>Dual-flush retrofit.</strong> Cuts flush use by 40%</div></li>
            <li><i class="fa fa-faucet-drip"></i><div><strong>Check inlet leak.</strong> 12-14 Mar spike suggests dripping joint</div></li>
            <li><i class="fa fa-bell"></i><div><strong>Set autopay.</strong> Skip late fees &middot; 1% cashback</div></li>
        </ul>
    </div>
</div>
