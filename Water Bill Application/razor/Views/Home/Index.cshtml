@{
    ViewBag.Title = "Dashboard";
    ViewBag.Route = "dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-head">
    <div>
        <h1 class="page-title">Good evening, @(ViewBag.UserFirstName ?? "Aarav")</h1>
        <div class="page-sub">Here's a quick look at your water connection.</div>
    </div>
    <div class="conn-pill">
        <i class="fa fa-home"></i>
        <div>
            <div class="conn-name">Sector 50 &middot; A-123</div>
            <div class="conn-id">NJL-20A-184721</div>
        </div>
        <i class="fa fa-chevron-down" style="color:var(--ink3);font-size:11px"></i>
    </div>
</div>

<!-- HERO BILL CARD -->
<div class="hero-card" data-style="gradient" style="margin-bottom:24px">
    <div class="blob"></div>
    <div class="hero-grid">
        <div>
            <div class="hero-tag"><span class="dot-y"></span> Bill Due &middot; March 2026</div>
            <div class="hero-label">Amount Payable</div>
            <div class="hero-amount"><span class="rupee">&#8377;</span><span class="num">@(ViewBag.AmountDue ?? "1,847")</span><span class="dec">.00</span></div>
            <div class="hero-meta">
                <div><i class="fa fa-calendar"></i> Due by <strong>15 May 2026</strong></div>
                <div><i class="fa fa-droplet"></i> 24.5 kL used</div>
                <div><i class="fa fa-receipt"></i> Bill <span class="mono">@(ViewBag.BillNo ?? "NJB-202603-84721")</span></div>
            </div>
            <div class="hero-cta">
                <a class="btn btn-on-hero" href="@Url.Action("PayBill","Home")"><i class="fa fa-bolt"></i> Pay &#8377;1,847 now</a>
                <a class="btn btn-on-hero ghost" href="@Url.Action("BillHistory","Home")"><i class="fa fa-file-arrow-down"></i> Download bill</a>
            </div>
        </div>
        <div class="hero-side">
            <div class="hero-kpi">
                <div class="hero-kpi-l">Avg. monthly</div>
                <div class="hero-kpi-v">&#8377; 1,564</div>
            </div>
            <div class="hero-kpi">
                <div class="hero-kpi-l">vs. last month</div>
                <div class="hero-kpi-v"><i class="fa fa-arrow-up"></i> 11.4%</div>
            </div>
            <div class="hero-kpi">
                <div class="hero-kpi-l">Tariff slab</div>
                <div class="hero-kpi-v">Domestic-II</div>
            </div>
        </div>
    </div>
</div>

<!-- LEAK ALERT -->
<div class="alert alert-warning">
    <i class="fa fa-triangle-exclamation"></i>
    <div class="alert-body">
        <div class="alert-title">Unusual usage detected on 12&ndash;14 Mar</div>
        <div class="alert-sub">Average daily flow spiked to 1.8&times; — possible leak in the inlet line. Inspect or raise a complaint.</div>
    </div>
    <a class="btn btn-sm" href="@Url.Action("Complaint","Home")">Inspect</a>
</div>

<!-- KPI ROW -->
<div class="kpi-row">
    <div class="stat-card">
        <div class="stat-label"><i class="fa fa-droplet"></i> This month</div>
        <div class="stat-value">24.5 <span>kL</span></div>
        <div class="stat-foot trend-up">+11.4% vs Feb</div>
    </div>
    <div class="stat-card">
        <div class="stat-label"><i class="fa fa-calendar-day"></i> Daily avg</div>
        <div class="stat-value">820 <span>L</span></div>
        <div class="stat-foot">Target: 750 L</div>
    </div>
    <div class="stat-card">
        <div class="stat-label"><i class="fa fa-coins"></i> Spent YTD</div>
        <div class="stat-value">&#8377; 4,953</div>
        <div class="stat-foot">3 cycles paid</div>
    </div>
    <div class="stat-card">
        <div class="stat-label"><i class="fa fa-leaf"></i> Eco score</div>
        <div class="stat-value">B+ <span>/A</span></div>
        <div class="stat-foot trend-up">12% under ward avg</div>
    </div>
</div>

<!-- LOWER GRID -->
<div class="two-col" style="margin-top:24px">
    <div class="panel">
        <div class="panel-head">
            <div>
                <div class="panel-title">12-month consumption</div>
                <div class="panel-sub">kL per month &middot; FY 2025-26</div>
            </div>
            <a href="@Url.Action("Analytics","Home")" class="panel-link">Details <i class="fa fa-arrow-right"></i></a>
        </div>
        <div class="chart-area">
            @{
                var months = new[] { "Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec","Jan","Feb","Mar" };
                var values = new[] { 18.2,22.4,27.8,31.2,28.5,24.1,22.6,19.8,18.4,20.1,22.0,24.5 };
                double max = 32;
            }
            <div class="bars">
                @for (int i = 0; i < months.Length; i++)
                {
                    var h = (int)Math.Round(values[i] / max * 100);
                    <div class="bar-wrap" title="@months[i]: @values[i] kL">
                        <div class="bar" style="height:@(h)%"></div>
                        <div class="bar-label">@months[i]</div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="panel">
        <div class="panel-head">
            <div class="panel-title">Quick actions</div>
        </div>
        <div class="quick-grid">
            <a class="quick" href="@Url.Action("PayBill","Home")"><i class="fa fa-bolt"></i>Pay bill</a>
            <a class="quick" href="@Url.Action("BillHistory","Home")"><i class="fa fa-file-arrow-down"></i>Download</a>
            <a class="quick" href="@Url.Action("Complaint","Home")"><i class="fa fa-wrench"></i>Complaint</a>
            <a class="quick" href="@Url.Action("NewConnection","Home")"><i class="fa fa-plus-circle"></i>New connection</a>
            <a class="quick" href="@Url.Action("Analytics","Home")"><i class="fa fa-chart-line"></i>Analytics</a>
            <a class="quick" href="@Url.Action("Profile","Home")"><i class="fa fa-user"></i>Profile</a>
        </div>
    </div>
</div>

<!-- RECENT BILLS -->
<div class="panel" style="margin-top:24px">
    <div class="panel-head">
        <div class="panel-title">Recent bills</div>
        <a href="@Url.Action("BillHistory","Home")" class="panel-link">All history <i class="fa fa-arrow-right"></i></a>
    </div>
    <table class="data-table">
        <thead>
            <tr><th>Bill no.</th><th>Period</th><th>Units</th><th class="r">Amount</th><th>Status</th><th></th></tr>
        </thead>
        <tbody>
            @if (ViewBag.RecentBills is System.Collections.IEnumerable bills)
            {
                foreach (dynamic b in bills)
                {
                    <tr>
                        <td><span class="mono">@b.Id</span></td>
                        <td>@b.Period</td>
                        <td>@b.Units kL</td>
                        <td class="r">&#8377; @b.Amount</td>
                        <td>
                            @if ((string)b.Status == "due")
                            { <span class="badge warn">Due 15 May</span> }
                            else
                            { <span class="badge ok">Paid</span> }
                        </td>
                        <td class="r"><a href="#" class="row-link"><i class="fa fa-download"></i></a></td>
                    </tr>
                }
            }
            else
            {
                <tr><td><span class="mono">NJB-202603-84721</span></td><td>Mar 2026</td><td>24.5 kL</td><td class="r">&#8377; 1,847</td><td><span class="badge warn">Due 15 May</span></td><td class="r"><a href="#" class="row-link"><i class="fa fa-download"></i></a></td></tr>
                <tr><td><span class="mono">NJB-202602-71204</span></td><td>Feb 2026</td><td>22.0 kL</td><td class="r">&#8377; 1,654</td><td><span class="badge ok">Paid</span></td><td class="r"><a href="#" class="row-link"><i class="fa fa-download"></i></a></td></tr>
                <tr><td><span class="mono">NJB-202601-58931</span></td><td>Jan 2026</td><td>20.1 kL</td><td class="r">&#8377; 1,512</td><td><span class="badge ok">Paid</span></td><td class="r"><a href="#" class="row-link"><i class="fa fa-download"></i></a></td></tr>
            }
        </tbody>
    </table>
</div>
