@{
    ViewBag.Title = "New Connection";
    ViewBag.Route = "newConnection";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-head"><div><h1 class="page-title">Apply for new connection</h1><div class="page-sub">For domestic, commercial, or institutional premises in Noida.</div></div></div>

<div class="two-col third">
    <div>
        <div class="panel">
            <div class="panel-title">Applicant details</div>
            @using (Html.BeginForm("NewConnection","Home",FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <div class="grid-2">
                    <div><label class="lbl">Full name</label><div class="field"><i class="fa fa-user"></i><input name="Name" placeholder="As per Aadhaar" /></div></div>
                    <div><label class="lbl">Aadhaar (last 4)</label><div class="field"><i class="fa fa-id-card"></i><input name="Aadhaar" maxlength="4" placeholder="XXXX" /></div></div>
                    <div><label class="lbl">Mobile</label><div class="field with-prefix"><span class="prefix">+91</span><input name="Mobile" maxlength="10" /></div></div>
                    <div><label class="lbl">Email</label><div class="field"><i class="fa fa-envelope"></i><input name="Email" /></div></div>
                </div>

                <hr class="hr-soft" />
                <div class="panel-title sm">Property</div>
                <div class="grid-2">
                    <div><label class="lbl">Sector / Block</label><div class="field"><i class="fa fa-location-dot"></i><input name="Sector" /></div></div>
                    <div><label class="lbl">Plot / House no.</label><div class="field"><input name="Plot" /></div></div>
                    <div><label class="lbl">Property type</label>
                        <select class="select w">
                            <option>Domestic &middot; Single dwelling</option>
                            <option>Domestic &middot; Multi-dwelling</option>
                            <option>Commercial</option>
                            <option>Institutional</option>
                            <option>Industrial</option>
                        </select>
                    </div>
                    <div><label class="lbl">Built-up area (sq.m)</label><div class="field"><input name="Area" /></div></div>
                </div>

                <hr class="hr-soft" />
                <div class="panel-title sm">Documents</div>
                <div class="upload-grid">
                    <label class="upload-tile"><i class="fa fa-file-image"></i> Aadhaar / ID proof<input type="file" hidden /></label>
                    <label class="upload-tile"><i class="fa fa-file"></i> Property papers<input type="file" hidden /></label>
                    <label class="upload-tile"><i class="fa fa-bolt"></i> Latest electricity bill<input type="file" hidden /></label>
                    <label class="upload-tile"><i class="fa fa-camera"></i> Site photo<input type="file" hidden /></label>
                </div>

                <div class="form-actions">
                    <a class="btn" href="@Url.Action("Index","Home")">Cancel</a>
                    <button type="submit" class="btn btn-primary">Submit application <i class="fa fa-arrow-right"></i></button>
                </div>
            }
        </div>
    </div>

    <div>
        <div class="panel">
            <div class="panel-title">Fee estimate</div>
            <table class="kv">
                <tr><th>Application fee</th><td class="r">&#8377; 500</td></tr>
                <tr><th>Security deposit</th><td class="r">&#8377; 3,000</td></tr>
                <tr><th>Connection charge</th><td class="r">&#8377; 4,500</td></tr>
                <tr><th>Meter</th><td class="r">&#8377; 1,200</td></tr>
            </table>
            <div class="total-row sm"><span>Estimated total</span><strong>&#8377; 9,200</strong></div>
            <div class="callout"><i class="fa fa-circle-info"></i> Final fee depends on site inspection. Payable after approval.</div>
        </div>

        <div class="panel" style="margin-top:18px">
            <div class="panel-title">Timeline</div>
            <ul class="timeline">
                <li class="done"><i class="fa fa-check"></i><div><strong>Submit application</strong><span>Today</span></div></li>
                <li><i class="fa fa-magnifying-glass"></i><div><strong>Verification</strong><span>2-3 working days</span></div></li>
                <li><i class="fa fa-house-flag"></i><div><strong>Site inspection</strong><span>~5 days</span></div></li>
                <li><i class="fa fa-coins"></i><div><strong>Payment of charges</strong><span>On approval</span></div></li>
                <li><i class="fa fa-droplet"></i><div><strong>Installation</strong><span>Within 7 working days</span></div></li>
            </ul>
        </div>
    </div>
</div>
