      <Query>
        <DataSourceName>ConStringSQL</DataSourceName>
        <CommandText>SELECT     BILL_NO, CON_TP, CONS_CTG, BILL_DATE, BILL_DUE_DATE, BILL_DATE_FROM, BILL_DATE_TO, MIN_RATE, CESS_AMT, AREAR, AREAR_TEXT, 
                      AREAR_INT, AREAR_INT_TEXT, LAST_BILL_EXTRA, CONS_NO, CONS_NM1, CONS_NM2, FLAT_TYPE, FLAT_NO, BLK_NO, SECTOR, property_no, 
                      PLOT_SIZE, PIPE_SIZE, REG_NO, CONN_DT, ESTI_NO, ESTI_AMT, SECU, ESTI_DT, ESTI1_AMT, DEV_TYPE, OLD_NEW_EN, OLD_NEW_UP, MOB_NO, 
                      EMAIL_ID, CONS_ADDRESS, STATUS, MIN_TOTAL_AMT, BILL_REBATE_PER, BILL_REBATE_AMT, TOTAL_BILL_AMT, BEFORE_DATE, AFTER_DATE, 
                      AFTER_DATE_AMT, Div_type
FROM         VIEW_JAL_BILL_MASTER</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
