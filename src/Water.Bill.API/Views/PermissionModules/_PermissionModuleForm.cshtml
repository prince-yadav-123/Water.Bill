@model PermissionModule
@{
    var isEdit = Model.Id != Guid.Empty;
}

<section class="wb-page-card wb-form-card">
    <form asp-action="@(isEdit ? "Edit" : "Create")" asp-route-id="@(isEdit ? Model.Id : null)" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input type="hidden" asp-for="Id" />
        <div class="row g-3">
            <div class="col-md-8">
                <label class="form-label" asp-for="Name">Module Name</label>
                <input class="form-control" asp-for="Name" required maxlength="100" placeholder="Roles &amp; Users" />
                <span class="text-danger" asp-validation-for="Name"></span>
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <label class="form-check mb-2">
                    <input class="form-check-input" asp-for="IsActive" />
                    <span class="form-check-label">Active</span>
                </label>
            </div>
        </div>
        <div class="wb-actions mt-4">
            <button class="btn btn-primary" type="submit">@(isEdit ? "Save Changes" : "Create Module")</button>
            <a class="btn btn-outline-primary" asp-action="Index">Cancel</a>
        </div>
    </form>
</section>
