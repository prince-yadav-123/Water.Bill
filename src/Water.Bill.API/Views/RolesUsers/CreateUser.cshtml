@model UserFormViewModel
@{
    ViewData["Title"] = "Create User";
    var roles = ViewBag.Roles as IEnumerable<Approle> ?? Enumerable.Empty<Approle>();
}

<div class="wb-page-head">
    <div>
        <h1>Create User</h1>
        <p>Create an authority user and assign a role.</p>
    </div>
    <a class="btn btn-outline-primary" asp-action="Users">Back</a>
</div>

<section class="wb-page-card wb-form-card">
    <form asp-action="CreateUser" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="row g-3">
            <div class="col-12">
                <label class="form-label" asp-for="FullName">Full Name</label>
                <input class="form-control" asp-for="FullName" required />
            </div>
            <div class="col-md-6">
                <label class="form-label" asp-for="Username">Username</label>
                <input class="form-control" asp-for="Username" required />
            </div>
            <div class="col-md-6">
                <label class="form-label" asp-for="Email">Email</label>
                <input class="form-control" asp-for="Email" type="email" required />
            </div>
            <div class="col-md-6">
                <label class="form-label" asp-for="PhoneNumber">Mobile Number</label>
                <input class="form-control" asp-for="PhoneNumber" />
            </div>
            <div class="col-md-6">
                <label class="form-label" asp-for="RoleId">Role</label>
                <select class="form-select" asp-for="RoleId" required>
                    <option value="">Select Role</option>
                    @foreach (var role in roles)
                    {
                        <option value="@role.Id">@role.Name</option>
                    }
                </select>
            </div>
            <div class="col-12">
                <label class="form-label" asp-for="Password">Password</label>
                <input class="form-control" asp-for="Password" type="password" required autocomplete="new-password" />
            </div>
            <div class="col-12">
                <label class="form-check">
                    <input class="form-check-input" asp-for="IsActive" />
                    <span class="form-check-label">Active user</span>
                </label>
            </div>
        </div>
        <div class="wb-actions mt-4">
            <button class="btn btn-primary" type="submit">Create User</button>
            <a class="btn btn-outline-primary" asp-action="Users">Cancel</a>
        </div>
    </form>
</section>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
