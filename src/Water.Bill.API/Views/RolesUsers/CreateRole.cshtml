@model Approle
@{
    ViewData["Title"] = "Create Role";
}

<div class="wb-page-head">
    <div>
        <h1>Create Role</h1>
        <p>Add a role that can be assigned to admin users.</p>
    </div>
    <a class="btn btn-outline-primary" asp-action="Index">Back</a>
</div>

<section class="wb-page-card wb-form-card">
    <form asp-action="CreateRole" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="mb-3">
            <label class="form-label" asp-for="Name">Role Name</label>
            <input class="form-control" asp-for="Name" required placeholder="Admin, Staff, Supervisor" />
            <span class="text-danger" asp-validation-for="Name"></span>
        </div>
        <div class="mb-3">
            <label class="form-label" asp-for="Description">Description</label>
            <input class="form-control" asp-for="Description" placeholder="Short role purpose" />
        </div>
        <div class="wb-actions">
            <button class="btn btn-primary" type="submit">Create Role</button>
            <a class="btn btn-outline-primary" asp-action="Index">Cancel</a>
        </div>
    </form>
</section>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
