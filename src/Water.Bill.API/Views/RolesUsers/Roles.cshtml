@model IReadOnlyList<Approle>
@{
    ViewData["Title"] = "Role Management";
    var userCounts = ViewBag.UserCounts as IReadOnlyDictionary<int, int> ?? new Dictionary<int, int>();
}

<div class="wb-page-head">
    <div>
        <h1>Role Management</h1>
        <p>Create and maintain authority roles independently from user accounts.</p>
    </div>
    <div class="wb-actions">
        <a class="btn btn-outline-primary" asp-action="Permissions">Role Permission</a>
        <a class="btn btn-primary" asp-action="CreateRole">New Role</a>
    </div>
</div>

<section class="wb-page-card wb-admin-card">
    <div class="wb-admin-toolbar">
        <div>
            <h2 class="wb-section-title">Roles</h2>
            <span>@Model.Count active role@(Model.Count == 1 ? "" : "s")</span>
        </div>
        <input id="roleSearch" class="form-control wb-search" type="search" placeholder="Search role name or description" oninput="filterRoles()" />
    </div>

    @if (!Model.Any())
    {
        <div class="wb-empty">No roles found. Create the first role to begin permission setup.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle wb-table wb-admin-table">
                <thead>
                    <tr>
                        <th>Role</th>
                        <th>Description</th>
                        <th>Users</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var role in Model)
                {
                    userCounts.TryGetValue(role.Id, out var userCount);
                    <tr class="role-row" data-search="@($"{role.Name} {role.Description}".ToLowerInvariant())">
                        <td>
                            <div class="fw-semibold">@role.Name</div>
                            <div class="text-muted small">Created @role.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</div>
                        </td>
                        <td>@(string.IsNullOrWhiteSpace(role.Description) ? "No description added" : role.Description)</td>
                        <td><span class="badge text-bg-secondary">@userCount user@(userCount == 1 ? "" : "s")</span></td>
                        <td>
                            <div class="wb-row-actions justify-content-end">
                                <a class="btn btn-sm btn-outline-primary" asp-action="RoleDetails" asp-route-id="@role.Id">View</a>
                                <a class="btn btn-sm btn-outline-primary" asp-action="EditRole" asp-route-id="@role.Id">Edit</a>
                                <form asp-action="DeleteRole" asp-route-id="@role.Id" method="post" onsubmit="return confirm('Delete this role?');">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>

@section Scripts {
<script>
function filterRoles() {
    var q = (document.getElementById('roleSearch').value || '').toLowerCase();
    document.querySelectorAll('.role-row').forEach(function(row) {
        row.style.display = row.dataset.search.includes(q) ? '' : 'none';
    });
}
</script>
}
