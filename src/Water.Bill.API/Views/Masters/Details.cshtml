@model Water.Bill.API.ViewModels.MasterFormViewModel

<div class="wb-page-head">
    <div>
        <h1>@Model.Title Details</h1>
        <p>Read-only view of the selected master record.</p>
    </div>
    <div class="wb-actions">
        <a class="btn btn-outline-secondary" asp-action="Index" asp-route-key="@Model.Key">Back</a>
        <a class="btn btn-primary" asp-action="Edit" asp-route-key="@Model.Key" asp-route-rowKey="@Model.RowKey">Edit</a>
    </div>
</div>

<section class="wb-page-card wb-admin-card">
    <div class="row g-3">
        @foreach (var field in Model.Fields)
        {
            <div class="col-12 col-md-6">
                <div class="text-muted small">@field.Label</div>
                <div class="fw-semibold">@(string.IsNullOrWhiteSpace(field.Value) ? "-" : field.Value)</div>
            </div>
        }
    </div>
</section>
