@model LoginRequestDto

@{
    ViewData["Title"] = "Admin Login";
}

<div class="wb-admin-login">
    <section class="wb-admin-login-hero" aria-label="Noida Jal administration">
        <div class="wb-admin-login-brand">
            <img class="wb-admin-login-logo" src="~/images/brand/noida-jal-logo.png" asp-append-version="true" alt="Noida Jal" />
            <div>
                <div class="wb-admin-login-brand-title">Noida Jal</div>
                <div class="wb-admin-login-brand-sub">Water Bill Administration</div>
            </div>
        </div>

        <div class="wb-admin-login-copy">
            <span class="wb-admin-login-eyebrow">Secure Admin Portal</span>
            <h1>Manage water billing operations with confidence.</h1>
            <p>Access consumers, billing, collections, role permissions, menu management, and security settings from one controlled workspace.</p>
        </div>

        <div class="wb-admin-login-metrics">
            <div>
                <strong>Role Based</strong>
                <span>Controlled module access</span>
            </div>
            <div>
                <strong>Audit Ready</strong>
                <span>Track sensitive activity</span>
            </div>
            <div>
                <strong>Responsive</strong>
                <span>Works across devices</span>
            </div>
        </div>
    </section>

    <section class="wb-admin-login-form-wrap" aria-label="Admin sign in">
        <div class="wb-admin-login-card">
            <div class="wb-admin-login-card-head">
                <div class="wb-admin-login-mark">AD</div>
                <div>
                    <h2>Welcome back</h2>
                    <p>Sign in with your admin username or email.</p>
                </div>
            </div>

            <form class="wb-admin-login-form" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="wb-admin-login-summary"></div>

                <div class="wb-admin-login-field">
                    <label asp-for="Username" class="form-label">Username or Email</label>
                    <div class="wb-admin-input-shell">
                        @* <span class="wb-admin-input-icon">U</span> *@
                        <input asp-for="Username" class="wb-admin-input" autocomplete="username" autofocus placeholder="admin@noidajal.local" />
                    </div>
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <div class="wb-admin-login-field">
                    <label asp-for="Password" class="form-label"></label>
                    <div class="wb-admin-input-shell">
                        <input asp-for="Password" class="wb-admin-input" autocomplete="current-password" placeholder="Enter password" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="wb-admin-login-options">
                    <label class="form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <span class="form-check-label">Keep me signed in</span>
                    </label>
                    <span class="wb-admin-login-help">Protected access</span>
                </div>

                <button type="submit" class="wb-admin-login-submit">Sign In</button>
            </form>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
