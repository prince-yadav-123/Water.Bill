{
  "openapi": "3.0.1",
  "info": {
    "title": "Water.Bill.API",
    "version": "1.0"
  },
  "paths": {
    "/api/Auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequestDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequestDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequestDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/": {
      "get": {
        "tags": [
          "Landing"
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/Landing": {
      "get": {
        "tags": [
          "Landing"
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/NewConnection/Apply": {
      "get": {
        "tags": [
          "NewConnection"
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      },
      "post": {
        "tags": [
          "NewConnection"
        ],
        "parameters": [
          {
            "name": "ApplicantName",
            "in": "query",
            "required": true,
            "schema": {
              "maxLength": 100,
              "minLength": 0,
              "type": "string"
            }
          },
          {
            "name": "FatherName",
            "in": "query",
            "schema": {
              "maxLength": 100,
              "minLength": 0,
              "type": "string"
            }
          },
          {
            "name": "MobileNumber",
            "in": "query",
            "required": true,
            "schema": {
              "pattern": "^([6-9]{1})([0-9]{9})$",
              "type": "string"
            }
          },
          {
            "name": "EmailId",
            "in": "query",
            "schema": {
              "maxLength": 50,
              "minLength": 0,
              "type": "string",
              "format": "email"
            }
          },
          {
            "name": "Address",
            "in": "query",
            "required": true,
            "schema": {
              "maxLength": 150,
              "minLength": 0,
              "type": "string"
            }
          },
          {
            "name": "Sector",
            "in": "query",
            "required": true,
            "schema": {
              "maxLength": 10,
              "minLength": 0,
              "type": "string"
            }
          },
          {
            "name": "Block",
            "in": "query",
            "required": true,
            "schema": {
              "maxLength": 10,
              "minLength": 0,
              "type": "string"
            }
          },
          {
            "name": "FlatNo",
            "in": "query",
            "required": true,
            "schema": {
              "maxLength": 15,
              "minLength": 0,
              "type": "string"
            }
          },
          {
            "name": "PlotSize",
            "in": "query",
            "required": true,
            "schema": {
              "maximum": 999999.99,
              "minimum": 1,
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "PipeSize",
            "in": "query",
            "schema": {
              "maximum": 999999.99,
              "minimum": 0.01,
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "KhasraNo",
            "in": "query",
            "schema": {
              "maxLength": 20,
              "minLength": 0,
              "type": "string"
            }
          },
          {
            "name": "VillageName",
            "in": "query",
            "schema": {
              "maxLength": 100,
              "minLength": 0,
              "type": "string"
            }
          },
          {
            "name": "VillageId",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "ConnectionCategory",
            "in": "query",
            "required": true,
            "schema": {
              "maxLength": 4,
              "minLength": 0,
              "type": "string"
            }
          },
          {
            "name": "ConnectionType",
            "in": "query",
            "required": true,
            "schema": {
              "maxLength": 10,
              "minLength": 0,
              "type": "string"
            }
          },
          {
            "name": "FlatType",
            "in": "query",
            "required": true,
            "schema": {
              "maxLength": 50,
              "minLength": 0,
              "type": "string"
            }
          },
          {
            "name": "PurposeOfConnection",
            "in": "query",
            "schema": {
              "maxLength": 50,
              "minLength": 0,
              "type": "string"
            }
          },
          {
            "name": "PreviousConnectionYesNo",
            "in": "query",
            "schema": {
              "maxLength": 1,
              "minLength": 0,
              "type": "string"
            }
          },
          {
            "name": "OtherConnection",
            "in": "query",
            "schema": {
              "maxLength": 150,
              "minLength": 0,
              "type": "string"
            }
          },
          {
            "name": "Rid",
            "in": "query",
            "schema": {
              "maxLength": 15,
              "minLength": 0,
              "type": "string"
            }
          },
          {
            "name": "DevType",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "DeclarationAccepted",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "Remarks",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/NewConnection/Track": {
      "get": {
        "tags": [
          "NewConnection"
        ],
        "parameters": [
          {
            "name": "applicationNo",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "mobileNumber",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      },
      "post": {
        "tags": [
          "NewConnection"
        ],
        "parameters": [
          {
            "name": "ApplicationNo",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "MobileNumber",
            "in": "query",
            "required": true,
            "schema": {
              "pattern": "^([6-9]{1})([0-9]{9})$",
              "type": "string"
            }
          },
          {
            "name": "Result.FatherName",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Result.EmailId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Result.Address",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Result.PlotSize",
            "in": "query",
            "schema": {
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "Result.PipeSize",
            "in": "query",
            "schema": {
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "Result.KhasraNo",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Result.VillageName",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Result.ConnectionCategory",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Result.ConnectionType",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Result.FlatType",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Result.PurposeOfConnection",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Result.PreviousConnectionYesNo",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Result.OtherConnection",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Result.SubmittedByConsumerNo",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Result.Documents",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/NewConnectionDocumentDto"
              }
            }
          },
          {
            "name": "Result.Timeline",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/NewConnectionApprovalHistoryDto"
              }
            }
          },
          {
            "name": "Result.Id",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "Result.ApplicationNo",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Result.ApplicationStatus",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Result.ApplicantName",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Result.MobileNumber",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Result.Sector",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Result.Block",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Result.FlatNo",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Result.SubmittedOn",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "Result.IsPublicApplication",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/NewConnection/Lookups/Blocks": {
      "get": {
        "tags": [
          "NewConnection"
        ],
        "parameters": [
          {
            "name": "sectorId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    },
    "/NewConnection/Lookups/ConnectionSubTypes": {
      "get": {
        "tags": [
          "NewConnection"
        ],
        "parameters": [
          {
            "name": "connectionCategoryId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "LoginRequestDto": {
        "required": [
          "password",
          "username"
        ],
        "type": "object",
        "properties": {
          "username": {
            "minLength": 1,
            "type": "string"
          },
          "password": {
            "minLength": 1,
            "type": "string",
            "format": "password"
          },
          "rememberMe": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "NewConnectionApprovalHistoryDto": {
        "type": "object",
        "properties": {
          "fromStatus": {
            "type": "string",
            "nullable": true
          },
          "toStatus": {
            "type": "string",
            "nullable": true
          },
          "action": {
            "type": "string",
            "nullable": true
          },
          "remarks": {
            "type": "string",
            "nullable": true
          },
          "actionByName": {
            "type": "string",
            "nullable": true
          },
          "actionByRole": {
            "type": "string",
            "nullable": true
          },
          "actionOn": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "NewConnectionDocumentDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "documentType": {
            "type": "string",
            "nullable": true
          },
          "fileName": {
            "type": "string",
            "nullable": true
          },
          "filePath": {
            "type": "string",
            "nullable": true
          },
          "uploadedOn": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      }
    }
  }
}