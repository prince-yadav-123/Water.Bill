{
  "ConnectionStrings": {
    "DefaultConnection": "server=localhost;port=3306;database=water_bill;user=root;password=Google@123;"
  },
  "Jwt": {
    "SecretKey": "CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_FOR_WATER_BILL",
    "Issuer": "Water.Bill",
    "Audience": "Water.Bill",
    "ExpiryMinutes": 60
  },
  "PortalUrls": {
    "AuthorityLogin": "/Account/Login",
    "ConsumerLogin": "https://localhost:7040/Account/Login"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/water-bill-api-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
