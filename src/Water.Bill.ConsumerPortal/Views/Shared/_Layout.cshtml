@using System.Security.Claims
@using Water.Bill.Application.Interfaces
@using Water.Bill.Application.DTOs.Menu
@using Water.Bill.Core.Common
@inject IPermissionService PermissionService

@{
    var currentPath = Context.Request.Path.Value ?? "";
    var tenantId = AppConstants.DefaultTenantId;
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var userName = User.Identity?.Name ?? "";
    var fullName = User.FindFirstValue("FullName") ?? userName;
    var consumerNo = User.FindFirstValue("ConsumerNo") ?? "";
    var profileImageUrl = User.FindFirstValue("ProfileImageUrl");
    var roleName = User.FindFirstValue(ClaimTypes.Role) ?? "";
    var displayName = string.IsNullOrWhiteSpace(fullName) ? userName : fullName;

    string GetInitials(string? name)
    {
        var parts = (name ?? string.Empty)
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (parts.Length == 0) return "U";
        if (parts.Length == 1) return parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant();
        return string.Concat(parts.Take(2).Select(x => x[0])).ToUpperInvariant();
    }

    var initials = GetInitials(displayName);

    IReadOnlyList<MenuItemDto> menuItems = [];
    HashSet<string> menuVisibleModules = [];
    HashSet<Guid> menuVisibleModuleIds = [];
    if (isAuthenticated && Guid.TryParse(User.FindFirstValue("RoleId"), out var roleId))
    {
        menuItems = await PermissionService.GetMenuTreeAsync(tenantId);
        menuVisibleModuleIds = await PermissionService.GetMenuVisibleModuleIdsAsync(roleId);
        menuVisibleModules = await PermissionService.GetMenuVisibleModulesAsync(roleId);
    }

    bool CanSeeSelf(MenuItemDto item)
    {
        if (!item.IsActive || !item.ShowInSidebar) return false;
        if (item.ModuleId.HasValue) return menuVisibleModuleIds.Contains(item.ModuleId.Value);
        if (!string.IsNullOrWhiteSpace(item.Module)) return menuVisibleModules.Contains(item.Module);
        return false;
    }

    IReadOnlyList<MenuItemDto> VisibleChildren(MenuItemDto item)
        => item.Children.Where(CanSeeSelf).OrderBy(x => x.Order).ToList();

    bool CanRender(MenuItemDto item)
        => item.Children.Count > 0
            ? VisibleChildren(item).Count > 0
            : CanSeeSelf(item);

    bool IsCurrent(MenuItemDto item)
    {
        if (!string.IsNullOrWhiteSpace(item.Url) &&
            currentPath.StartsWith(item.Url, StringComparison.OrdinalIgnoreCase))
            return true;

        return item.Children.Any(IsCurrent);
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Noida Jal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="wb-body" data-sidebar-storage-key="water-bill-consumer-sidebar-collapsed">
    @await Html.PartialAsync("_WaterLoader")

    @if (isAuthenticated)
    {
        <div class="wb-sidebar-backdrop" data-sidebar-dismiss></div>
        <aside class="wb-sidebar" id="consumerSidebar">
            <div class="wb-brand">
                @* <img class="wb-brand-logo" src="~/images/brand/noida-jal-logo.png" asp-append-version="true" alt="Noida Jal" /> *@
                <div class="wb-brand-copy">
                    <div class="wb-brand-title">Noida Jal</div>
                    <div class="wb-brand-sub">Consumer Services</div>
                </div>
                <button class="wb-sidebar-toggle" type="button" data-sidebar-toggle aria-label="Toggle sidebar">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
            </div>
            <nav class="wb-nav">
                @foreach (var item in menuItems.Where(CanRender).OrderBy(x => x.Order))
                {
                    var children = VisibleChildren(item);
                    var hasChildren = children.Count > 0;
                    var isOpen = IsCurrent(item);
                    var itemId = $"menu-{item.Id:N}";

                    if (hasChildren)
                    {
                        <div class="wb-nav-group @(isOpen ? "open" : "")">
                            <button class="wb-nav-link wb-nav-parent @(isOpen ? "active" : "")" type="button" data-menu-toggle aria-expanded="@isOpen.ToString().ToLowerInvariant()" aria-controls="@itemId">
                                <span class="wb-nav-icon">@item.Icon</span>
                                <span class="wb-nav-text">@item.Label</span>
                                <span class="wb-nav-arrow"></span>
                            </button>
                            <div class="wb-nav-children" id="@itemId">
                                @foreach (var child in children)
                                {
                                    <a class="wb-nav-link wb-nav-child @(IsCurrent(child) ? "active" : "")" href="@(child.Url ?? "#")" target="@(child.OpenInNewTab ? "_blank" : null)">
                                        <span class="wb-nav-icon">@(string.IsNullOrWhiteSpace(child.Icon) ? "[]" : child.Icon)</span>
                                        <span class="wb-nav-text">@child.Label</span>
                                    </a>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <a class="wb-nav-link @(IsCurrent(item) ? "active" : "")" href="@(item.Url ?? "#")" target="@(item.OpenInNewTab ? "_blank" : null)">
                            <span class="wb-nav-icon">@item.Icon</span>
                            <span class="wb-nav-text">@item.Label</span>
                        </a>
                    }
                }
            </nav>
            <div class="wb-sidebar-bottom">
                <a class="wb-nav-link" asp-controller="Profile" asp-action="Index">
                    <span class="wb-nav-icon">P</span>
                    <span class="wb-nav-text">Profile</span>
                </a>
                <a class="wb-nav-link" asp-controller="Profile" asp-action="UpdateContact">
                    <span class="wb-nav-icon">U</span>
                    <span class="wb-nav-text">Update Mobile/Email</span>
                </a>
                <a class="wb-nav-link" asp-controller="NewConnection" asp-action="Apply">
                    <span class="wb-nav-icon">C</span>
                    <span class="wb-nav-text">New Connection</span>
                </a>
                <a class="wb-nav-link" asp-controller="NewConnection" asp-action="MyApplications">
                    <span class="wb-nav-icon">A</span>
                    <span class="wb-nav-text">My Applications</span>
                </a>
                <a class="wb-nav-link" asp-controller="Account" asp-action="Logout">
                    <span class="wb-nav-icon">L</span>
                    <span class="wb-nav-text">Logout</span>
                </a>
            </div>
        </aside>
    }

    <main class="@(isAuthenticated ? "wb-main" : "wb-main-full")">
        @if (isAuthenticated)
        {
            <header class="wb-topbar">
                <div class="d-flex align-items-center gap-2">
                    <button class="wb-mobile-menu" type="button" data-sidebar-toggle aria-label="Open menu">
                        <span></span>
                        <span></span>
                        <span></span>
                    </button>
                    <div class="fw-semibold">@ViewData["Title"]</div>
                </div>
                <a class="wb-profile-chip" asp-controller="Profile" asp-action="Index" title="Open My Profile">
                    <span class="wb-profile-avatar" aria-hidden="true">
                        @if (!string.IsNullOrWhiteSpace(profileImageUrl))
                        {
                            <img src="@profileImageUrl" alt="" />
                        }
                        else
                        {
                            @initials
                        }
                    </span>
                    <span class="wb-profile-copy">
                        <span class="wb-profile-name">@displayName</span>
                        <span class="wb-profile-meta">@(string.IsNullOrWhiteSpace(consumerNo) ? roleName : consumerNo)</span>
                    </span>
                </a>
            </header>
        }

        <section class="wb-content">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="wb-toast-stack">
                    <div class="alert alert-success wb-toast-message">
                        <span class="wb-toast-icon">✓</span>
                        <span>@TempData["SuccessMessage"]</span>
                    </div>
                </div>
            }
            @RenderBody()
        </section>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
