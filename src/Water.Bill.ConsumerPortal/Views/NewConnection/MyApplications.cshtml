@model IReadOnlyList<Water.Bill.Application.DTOs.NewConnection.NewConnectionApplicationSummaryDto>
@{
    ViewData["Title"] = "My Applications";
    var isPublic = ViewData["IsPublicNewConnection"] as bool? == true;
    bool NeedsPayment(string status) => status is "PendingPayment" or "FeePending" or "PaymentFailed";
}

<div class="wb-newconn-page-shell">
    <div class="wb-page-head">
        <div>
            <p class="wb-kicker">New Connection</p>
            <h1>My Applications</h1>
            <p>Track the new connection requests submitted @(isPublic ? "with your verified mobile number" : "from your consumer account").</p>
        </div>
        <a class="btn btn-primary" asp-action="Apply">@(isPublic ? "Apply for Another New Connection" : "Apply for New Connection")</a>
    </div>

    <section class="wb-page-card">
        @if (Model.Count == 0)
        {
            <div class="wb-empty-state">
                <strong>No applications found.</strong>
                <span>Your new connection requests will appear here after submission.</span>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table wb-table align-middle">
                    <thead>
                        <tr>
                            <th>Application No</th>
                            <th>Applicant</th>
                            <th>Property</th>
                            <th>Status</th>
                            <th>Fee</th>
                            <th>Submitted</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@item.ApplicationNo</strong></td>
                                <td>@item.ApplicantName</td>
                                <td>@item.Sector / @item.Block / @item.FlatNo</td>
                                <td><span class="badge text-bg-primary">@item.ApplicationStatus</span></td>
                                <td>
                                    @if (item.TotalFee.HasValue)
                                    {
                                        <span>@item.TotalFee.Value.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("en-IN"))</span>
                                        <small class="d-block text-muted">@(!string.IsNullOrWhiteSpace(item.PaymentStatus) ? item.PaymentStatus : "Pending")</small>
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>
                                <td>@(item.SubmittedOn?.ToString("dd MMM yyyy") ?? "-")</td>
                                <td class="text-end">
                                    @if (item.CanContinue)
                                    {
                                        if (NeedsPayment(item.ApplicationStatus) && item.TotalFee.HasValue)
                                        {
                                            <a class="btn btn-sm btn-primary" asp-action="Payment" asp-route-id="@item.Id">Continue Payment</a>
                                        }
                                        else
                                        {
                                            <a class="btn btn-sm btn-primary" asp-action="Continue" asp-route-id="@item.Id">Complete Application</a>
                                        }
                                    }
                                    <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@item.Id">View</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>
