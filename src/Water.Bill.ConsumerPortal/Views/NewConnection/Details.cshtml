@model Water.Bill.Application.DTOs.NewConnection.NewConnectionApplicationDetailsDto
@{
    ViewData["Title"] = "Application Details";
}

<div class="wb-newconn-page-shell">
    <div class="wb-page-head">
        <div>
            <p class="wb-kicker">New Connection</p>
            <h1>@Model.ApplicationNo</h1>
            <p>Application details and status timeline.</p>
        </div>
        <a class="btn btn-outline-primary" asp-action="MyApplications">Back to Applications</a>
    </div>

    @await Html.PartialAsync("~/Views/NewConnection/_NewConnectionDetailsCard.cshtml", Model)
</div>
