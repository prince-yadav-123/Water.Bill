@model Water.Bill.ConsumerPortal.ViewModels.ConsumerNdcIndexViewModel
@{
    string DateText(DateTime? value) => value.HasValue ? value.Value.ToString("dd MMM yyyy") : "-";
    string StatusText(Water.Bill.Infrastructure.Data.Entities.ConsumerApplyNdc app)
        => !string.IsNullOrWhiteSpace(app.FinalStatus) ? app.FinalStatus!
            : !string.IsNullOrWhiteSpace(app.CurrentStatus) ? app.CurrentStatus!
            : !string.IsNullOrWhiteSpace(app.Status) ? app.Status!
            : "Pending";
    bool CanPrint(Water.Bill.Infrastructure.Data.Entities.ConsumerApplyNdc app)
        => string.Equals(app.FinalStatus, "A", StringComparison.OrdinalIgnoreCase)
            || string.Equals(app.CurrentStatus, "Approved", StringComparison.OrdinalIgnoreCase)
            || string.Equals(app.CurrentStatus, "FinalApproved", StringComparison.OrdinalIgnoreCase)
            || string.Equals(app.Status, "A", StringComparison.OrdinalIgnoreCase)
            || !string.IsNullOrWhiteSpace(app.CertificateUrl);
    string BadgeClass(string status) => status switch
    {
        "A" or "Approved" => "text-bg-success",
        "C" or "R" or "Rejected" => "text-bg-danger",
        "Submitted" => "text-bg-primary",
        _ => "text-bg-secondary"
    };
}

<div class="wb-newconn-page-shell">
    <div class="wb-page-head">
        <div>
            <p class="wb-kicker">No Dues Certificate</p>
            <h1>NDC / No Dues</h1>
            <p>Apply for a No Dues Certificate and track your submitted NDC applications.</p>
        </div>
        <a class="btn btn-primary" asp-action="Apply">Apply for NDC</a>
    </div>

    <section class="wb-page-card">
        <form method="get" class="wb-filter-bar">
            <div class="wb-filter-field wb-filter-search">
                <label class="form-label">Search</label>
                <input class="form-control" type="search" name="search" value="@Model.Search" placeholder="Application, consumer, name" />
            </div>
            <div class="wb-filter-field">
                <label class="form-label">Status</label>
                <select class="form-select" name="status">
                    <option value="">All Status</option>
                    <option value="Submitted" selected="@(Model.Status == "Submitted")">Submitted</option>
                    <option value="A" selected="@(Model.Status == "A")">Approved</option>
                    <option value="R" selected="@(Model.Status == "R")">Rejected</option>
                </select>
            </div>
            <div class="wb-filter-actions">
                <button class="btn btn-primary" type="submit">Filter</button>
                <a class="btn btn-outline-secondary" asp-action="Index">Reset</a>
            </div>
        </form>

        @if (Model.Applications.Count == 0)
        {
            <div class="wb-empty-state">
                <strong>No NDC applications found.</strong>
                <span>Your submitted No Dues Certificate requests will appear here.</span>
            </div>
        }
        else
        {
            <div class="table-responsive wb-approval-table-wrap">
                <table class="table align-middle wb-table wb-approval-table">
                    <thead>
                    <tr>
                        <th>Application No</th>
                        <th>Consumer</th>
                        <th>Mobile</th>
                        <th>Property</th>
                        <th>Status</th>
                        <th>Submitted</th>
                        <th class="text-end">Action</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.Applications)
                    {
                        var status = StatusText(item);
                        <tr>
                            <td><strong>@item.ApplicationNo</strong></td>
                            <td>
                                <strong>@(item.ConsumerNo ?? "-")</strong>
                                <small class="d-block text-muted">@(item.ConsName ?? "-")</small>
                            </td>
                            <td>@(item.MobileNo ?? "-")</td>
                            <td>@($"{item.Sector} / {item.Block}-{item.PlotNo}".Trim(' ', '/', '-'))</td>
                            <td><span class="badge @BadgeClass(status)">@status</span></td>
                            <td>@DateText(item.CreatedOn)</td>
                            <td class="text-end">
                                @if (CanPrint(item))
                                {
                                    <a class="btn btn-sm btn-primary" asp-action="Certificate" asp-route-id="@item.AutoId" target="_blank">Print Certificate</a>
                                }
                                <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@item.AutoId">View</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>
